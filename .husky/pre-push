#!/usr/bin/env sh
# Pre-push: full quality gate. Runs four checks in order. Any failure
# blocks the push. All checks live here (not split to pre-commit) so
# commits are fast and batch-friendly per user preference.

set -e

echo "[pre-push] 1/4 Unit tests..."
npm test

echo "[pre-push] 2/4 ESLint..."
npm run lint

echo "[pre-push] 3/4 TypeScript type check..."
npx tsc --noEmit

echo "[pre-push] 4/4 Next.js production build..."
npm run build

echo "[pre-push] All checks passed. Safe to push."
