# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
MONETIZATION_PLAN.md

# Preview / scratch folders. Used for design bake-offs (10 login layouts,
# 10 blog layouts, etc.) that live locally, get reviewed, one is picked,
# and the folder is deleted. Never commit these to main.
app/*-preview/
app/login-preview/

# Local-only advisory / review docs that live at the repo root. Created
# by marketing review passes for offline viewing, never meant for prod.
/MARKETING_REVIEW.html
/MARKETING_REVIEW_V2.html
/FEATURES_PLAN.html

# tooling state (not for commit)
.claude/
supabase/.temp/

# Playwright test artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
