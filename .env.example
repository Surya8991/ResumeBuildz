# ResumeBuildz Environment Variables
#
# Copy this file to .env.local and fill in the values.
# Without any vars set the app runs in guest mode (localStorage only, no auth, no billing).
#
# Groq AI: No server-side key needed. Users supply their own key in the browser.
# Get a free Groq API key at: https://console.groq.com/keys

# ─── Database (Neon PostgreSQL — free tier) ───────────────────────────────────
# Sign up at neon.tech → create a project → copy the connection string.
# Free tier: 512 MB, no credit card required.
#
# IMPORTANT for serverless/Vercel: enable "Connection pooling" in Neon and use
# the POOLED string (host contains "-pooler"). The direct host works locally but
# can intermittently fail with "fetch failed" under serverless concurrency.
#   Pooled: postgresql://user:password@ep-xxx-pooler.c-2.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
# Generate a strong random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=your_random_secret_here

# Google OAuth — get from console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs (add BOTH):
#   http://localhost:3000/api/auth/callback/google       (local dev)
#   https://yourdomain.com/api/auth/callback/google       (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Canonical origin for OAuth redirects and share-link generation.
# NOTE: this is a NEXT_PUBLIC_* var — baked in at BUILD time. Set it in your host
# (e.g. Vercel) to your production URL and redeploy; changing it requires a rebuild.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Storage — Cloudflare R2 (optional, free tier: 10 GB + zero egress) ───────
# Sign up at cloudflare.com → R2 → Create bucket.
# Omit all R2 vars to disable avatar uploads.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resumebuildz
# Public URL for the R2 bucket (enable public access in Cloudflare dashboard)
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Stripe (Billing) ─────────────────────────────────────────────────────────
# Omit all Stripe vars to disable paid plans entirely (free tier still works).
# Get keys from dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for each plan — from Stripe dashboard → Products.
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_TEAM=
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Resend powers all transactional email: welcome email on signup, password
# reset, share invites, and contact-form notifications. Omit RESEND_API_KEY to
# disable email entirely — every feature degrades gracefully (share UI falls
# back to "copy link", contact messages still save to the DB).
# Get your API key from resend.com → API Keys.
RESEND_API_KEY=

# From address for outgoing email. Must be a domain you've verified in Resend.
# SHARE_INVITE_FROM is the primary; WELCOME_FROM is an optional override.
SHARE_INVITE_FROM=ResumeBuildz <noreply@yourdomain.com>
WELCOME_FROM=

# Where contact-form submissions are emailed (Reply-To is set to the sender).
# Omit to skip notifications — messages still persist in the contact_messages table.
CONTACT_NOTIFY_TO=

# ─── Superadmin Bootstrap ─────────────────────────────────────────────────────
# Comma-separated list of emails auto-promoted to superadmin on first signup.
# e.g. SUPERADMIN_EMAIL=alice@example.com,bob@example.com
# For existing accounts: UPDATE profiles SET role = 'superadmin' WHERE id = '<user-id>';
# Once one superadmin exists, additional superadmins/admins can be promoted via /admin/users.
SUPERADMIN_EMAIL=

# ─── Cron & Admin ─────────────────────────────────────────────────────────────
# Shared secret for scheduled jobs and operator-only endpoints. Vercel Cron
# injects "Authorization: Bearer $CRON_SECRET" automatically when set here +
# in Vercel env. Gates: /api/cron/* (e.g. resume-reminders) and
# /api/admin/broadcast (product-update email blast). Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Rate Limiting (Upstash Redis) ────────────────────────────────────────────
# Optional. When set, every public write endpoint (share invite, waitlist,
# contact, checkout) gets a *real* per-IP/per-route limit shared across every
# Lambda instance and region. Without these the limiter degrades to a per-
# process in-memory burst guard — fine for dev/self-host, easy to bypass on
# Vercel because each Lambda instance has its own counter.
# Get from console.upstash.com → Create Database → REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Analytics & Monitoring ───────────────────────────────────────────────────
# Sentry (optional). Leave blank to disable error monitoring.
NEXT_PUBLIC_SENTRY_DSN=
