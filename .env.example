# ResumeBuildz Environment Variables
#
# Copy this file to .env.local and fill in the values.
# Without any vars set the app runs in guest mode (localStorage only, no auth, no billing).
#
# Groq AI: No server-side key needed. Users supply their own key in the browser.
# Get a free Groq API key at: https://console.groq.com/keys

# ─── Database (Neon PostgreSQL — free tier) ───────────────────────────────────
# Sign up at neon.tech → create a project → copy the connection string.
# Free tier: 512 MB, no credit card required.
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
# Generate a strong random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=your_random_secret_here

# Google OAuth — get from console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Canonical origin for OAuth redirects and share-link generation.
# Change to your production URL before deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Storage — Cloudflare R2 (optional, free tier: 10 GB + zero egress) ───────
# Sign up at cloudflare.com → R2 → Create bucket.
# Omit all R2 vars to disable avatar uploads.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resumebuildz
# Public URL for the R2 bucket (enable public access in Cloudflare dashboard)
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Stripe (Billing) ─────────────────────────────────────────────────────────
# Omit all Stripe vars to disable paid plans entirely (free tier still works).
# Get keys from dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for each plan — from Stripe dashboard → Products.
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_TEAM=
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=

# ─── Email (Share Invites) ────────────────────────────────────────────────────
# Resend is used to send share-invite emails. Omit to disable email; the UI
# falls back to "copy link" mode automatically.
# Get your API key from resend.com → API Keys.
RESEND_API_KEY=

# From address for share-invite emails.
# Must be a domain you've verified in Resend.
SHARE_INVITE_FROM=ResumeBuildz <noreply@yourdomain.com>

# ─── Analytics & Monitoring ───────────────────────────────────────────────────
# Sentry (optional). Leave blank to disable error monitoring.
NEXT_PUBLIC_SENTRY_DSN=
